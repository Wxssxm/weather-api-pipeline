# Weather API Pipeline — environment configuration
# Copy to .env and adjust as needed. Never commit .env.

# Postgres connection (used both inside docker-compose and from host scripts)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=weather
POSTGRES_USER=weather
POSTGRES_PASSWORD=weather_dev_only

# When the app runs INSIDE the docker-compose network, override the host:
# POSTGRES_HOST=postgres

# Open-Meteo API
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
HTTP_TIMEOUT_SECONDS=20
HTTP_MAX_RETRIES=4

# Scheduler
SCHEDULE_CRON_HOUR="*"
SCHEDULE_CRON_MINUTE="5"
INGEST_ON_STARTUP=true

# Logging
LOG_LEVEL=INFO
