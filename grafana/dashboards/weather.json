      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT o.observed_at AS time, c.name AS metric, o.relative_humidity_pct AS value FROM weather_observations o JOIN cities c ON c.id = o.city_id WHERE o.observed_at > NOW() - INTERVAL '24 hours' ORDER BY o.observed_at",
          "refId": "A"
        }
