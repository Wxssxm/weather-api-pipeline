      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT c.name, MAX(o.wind_speed_kmh) AS peak_wind_kmh FROM weather_observations o JOIN cities c ON c.id = o.city_id WHERE o.observed_at > NOW() - INTERVAL '24 hours' GROUP BY c.name ORDER BY peak_wind_kmh DESC",
          "refId": "A"
