      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT o.observed_at AS time, c.name AS metric, o.temperature_c AS value FROM weather_observations o JOIN cities c ON c.id = o.city_id WHERE o.observed_at > NOW() - INTERVAL '7 days' ORDER BY o.observed_at",
          "refId": "A"
        }
      ],
      "title": "Temperature by city (last 7 days)",
